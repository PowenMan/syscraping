{
  "name": "syscraping",
  "version": "1.0.0",
  "private": true,
  "description": "Scraper base en Node.js con Playwright para extraer contenido relacionado con palabras clave.",
  "type": "module",
  "scripts": {
    "scrape": "node ./src/index.js",
