{
  "name": "syscraping",
  "version": "1.0.0",
  "private": true,
  "description": "Scraper base en Node.js con Playwright para extraer contenido relacionado con palabras clave.",
  "type": "module",
  "scripts": {
    "test": "node --test ./tests/*.test.js",
    "scrape": "node ./src/index.js",
    "scrape:config": "node ./src/index.js --config ./scraper.config.json",
    "start": "node ./src/server.js",
    "local:start": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "local:stop": "powershell -ExecutionPolicy Bypass -File ./scripts/stop-local.ps1",
    "local:status": "powershell -ExecutionPolicy Bypass -File ./scripts/status-local.ps1",
    "local:restart": "powershell -ExecutionPolicy Bypass -File ./scripts/restart-local.ps1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "mysql2": "^3.20.0",
    "playwright": "^1.54.2",
    "xlsx": "^0.18.5"
  }
}
